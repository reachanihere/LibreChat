# Force LF line endings for shell scripts and git hooks (required for cross-platform compatibility)
.husky/* text eol=lf
*.sh text eol=lf

# Azure/Copilot deploy overlay: these files are consumed on the Linux VM
# (Caddy, docker compose, LibreChat config) — CRLF must never reach them.
*.yml text eol=lf
*.yaml text eol=lf
Caddyfile text eol=lf
*.env text eol=lf
